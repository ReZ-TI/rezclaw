{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RezClaw manifest",
  "type": "object",
  "required": ["project", "content_revision", "updated_at", "modules"],
  "properties": {
    "project": { "type": "string" },
    "content_revision": { "type": "integer", "minimum": 1 },
    "updated_at": { "type": "string", "format": "date-time" },
    "changelog": { "type": "string" },
    "mirrors": { "type": "object" },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "public": { "type": "object" },
          "dify": { "type": "object" }
        }
      }
    },
    "healthcheck_urls": {
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    }
  }
}
